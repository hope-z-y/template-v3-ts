# 复制为 .env.local 后填写本地私有配置（.env.local 不会被 git 跟踪） #


# 系统名称
VITE_APP_NAME = 'Admin System'

# API 请求前缀
VITE_API_PREFIX = '/api'


# 代理目标地址
VITE_PROXY_TARGET = 'http://localhost:10086'

# 路由前缀
VITE_ROUTE_PREFIX = '/'

# 请求超时时间（毫秒）
VITE_API_TIMEOUT = 15000

# 认证存储策略：memory-refresh | legacy-localStorage
VITE_AUTH_STORAGE_STRATEGY = 'memory-refresh'
