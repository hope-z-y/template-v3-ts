# 开发环境 #


# 系统名称
VITE_APP_NAME = 'Admin System'

# API 请求前缀
VITE_API_PREFIX = '/proxy-api'


# Vite 代理目标地址
VITE_PROXY_TARGET = 'http://localhost:15387/'

# 路由前缀
VITE_ROUTE_PREFIX = '/'

# 请求超时时间（毫秒）
VITE_API_TIMEOUT = 15000

# 认证存储策略：memory-refresh | legacy-localStorage
VITE_AUTH_STORAGE_STRATEGY = 'memory-refresh'

# 是否信任菜单树按钮权限：默认 false，权限以 /auth/profile.permissions 为准
VITE_TRUST_MENU_PERMISSIONS = 'false'
