# 所有环境 #


# 系统名称
VITE_APP_NAME = 'Admin System'

# API 请求前缀
VITE_API_PREFIX = '/api'

# 代理目标地址
VITE_PROXY_TARGET = 'http://localhost:3000'

# 路由前缀
VITE_ROUTE_PREFIX = '/'

# 请求超时时间（毫秒）
VITE_API_TIMEOUT = 15000

# 是否开启请求参数加密
VITE_ENCRYPTION_ENABLED = false

# 请求参数加密密钥
VITE_REQUEST_ENCRYPTION_KEY = '123456'

# 响应数据解密密钥
VITE_RESPONSE_ENCRYPTION_KEY = '123456'
